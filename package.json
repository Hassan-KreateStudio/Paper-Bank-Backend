{
  "name": "paper-bank-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "dev:bun": "bun --watch src/index.ts",
    "cf:typegen": "wrangler types",
    "deploy:dry": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "lint": "bunx tsc --project tsconfig.ci.json --noEmit --pretty false",
    "typecheck": "bunx tsc --project tsconfig.ci.json --noEmit",
    "check": "bun run lint && bun run typecheck",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "hono": "^4.12.26",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260614.0",
    "@types/pngjs": "^6.0.5",
    "bun-types": "^1.3.14",
    "wrangler": "^4.104.0"
  }
}
